# APIMart credentials for AI image generation (server-side only — never commit the real .env).
# Get your key from https://api.apimart.ai . The backend also falls back to
# ~/.config/apimart/api_key if this is unset.
APIMART_API_KEY=your_apimart_key_here

# Optional overrides:
# APIMART_IMAGE_MODEL=gpt-image-2
# APIMART_POLL_TIMEOUT=180
# APIMART_INITIAL_WAIT=8
